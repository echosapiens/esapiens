# ── E.sapiens v2 Backend Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your keys before running.
#
#   cp backend/.env.example backend/.env
# ────────────────────────────────────────────────────────────────────────────

# OpenRouter API key — required for LLM calls
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-actual-key-here

# ── Persistent Storage ──────────────────────────────────────────────────────
# Directory where all session data, checkpoints, and user workspaces are stored.
# Default: /root/persistent (used by Docker volume mount).
# For local development, set to a writable path like ./data
# ESAPIENS_DATA_DIR=/root/persistent
ESAPIENS_DATA_DIR=./data