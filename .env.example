# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://esapiens:esapiens@localhost:5432/esapiens

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ───────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Modal (compute sandbox) ─────────────────────────────────────────
MODAL_APP_NAME=esapiens-pipelines
MODAL_TIMEOUT=600

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── ORCID OAuth ──────────────────────────────────────────────────────
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:8000/auth/orcid/callback

# ── OpenRouter LLM ──────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Outbox relay ────────────────────────────────────────────────────
OUTBOX_RELAY_INTERVAL_SECONDS=2
OUTBOX_REDIS_CHANNEL=esapiens:events